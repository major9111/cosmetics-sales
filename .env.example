# ─────────────────────────────────────────────
# Cosmetica — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Django
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False

# Supabase PostgreSQL connection string
# Get from: Supabase → Project → Settings → Database → Connection String (URI mode)
# Use the "Session mode" string on port 5432
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# OpenAI (for AI receipt scanning)
OPENAI_API_KEY=sk-...

# Optional: your custom domain (e.g. cosmetica.yourdomain.com)
CUSTOM_DOMAIN=
